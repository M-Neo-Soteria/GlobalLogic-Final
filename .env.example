# Example Environment Configuration
# Copy this file to .env and fill in your actual values

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
# Get this from MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://admin:YourSecurePassword123@facility-cluster.mongodb.net/facility-checklist?retryWrites=true&w=majority

# Server Port
PORT=5000

# Node Environment
# Options: development, production
NODE_ENV=development

# Optional: API Rate Limiting (future enhancement)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Optional: Email Notifications (future enhancement)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: Logging Level
# LOG_LEVEL=info
